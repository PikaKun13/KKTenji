{
  "name": "kktenji",
  "private": true,
  "version": "0.1.0",
  "description": "PPT/Markdown deck を思維関係図として描画・プレゼンする Windows ツール",
  "author": "PikaKun13",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "jp.kktenji.app",
    "productName": "KKTenji",
    "directories": { "output": "dist" },
    "files": [
      "dist-web/**",
      "electron/**",
      "scripts/**",
      "sample/**",
      "build/icon.ico",
      "package.json"
    ],
    "win": { "target": "nsis", "icon": "build/icon.ico" },
    "fileAssociations": [
      {
        "ext": "tenji",
        "name": "KKTenji deck",
        "description": "KKTenji 関係図 deck",
        "icon": "build/icon.ico",
        "role": "Viewer"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "KKTenji-Setup-${version}.${ext}",
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "dompurify": "^3.2.4",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
